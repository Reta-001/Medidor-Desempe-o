{
  "mcpServers": {
    "postgres": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://postgres:cris2001@localhost:5432/desempeño"
      ]
    },
    "monitor-operacional": {
      "command": "npm",
      "args": [
        "--workspace",
        "server",
        "run",
        "mcp"
      ],
      "env": {
        "DATABASE_URL": "postgresql://postgres:cris2001@localhost:5432/desempe%C3%B1o"
      }
    }
  }
}
